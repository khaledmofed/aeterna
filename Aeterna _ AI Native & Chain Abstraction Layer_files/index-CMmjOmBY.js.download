ct:"Connect",testnetV2:"Testnet V2.1"},hero:{consensusLive:"Aeterna DAG + Aeterna Consensus Live",chain:"CHAIN",abstraction:"ABSTRACTION",description:"RWA Infrastructure for the Open UBI Era. Control 15+ chains with {oneAddress} one Universal Address{/oneAddress}. Empower AI Agents with {autonomous} Autonomous Execution{/autonomous} and {trustless} Trustless Payments{/trustless}.",launchAIAgent:"Launch AI Agent",readWhitepaper:"Read Whitepaper",tps:"TPS (Aeterna DAG)",finality:"Finality",architecturalLayers:"Architectural Layers",onChainAI:"On-Chain AI"},features:{title:"The 4-Layer",subtitle:"Architecture Blueprint",description:"Decoupled, Modular, and Sovereign. Built for RWA Infrastructure and Open UBI.",infrastructure:{title:"Infrastructure",subtitle:"Layer 1",desc:"Aeterna Core + Aeterna SDK. Aeterna DAG + Aeterna Consensus achieves 160K+ TPS with sub-100ms finality. Includes Aeterna DA and Aeterna Storage."},aiCore:{title:"AI Engine",subtitle:"Layer 2",desc:"Decentralized Aeterna AgentCore. On-chain orchestrator, Aeterna Inference for verifiable AI, Aeterna Subnet for incentives, Aeterna Memory for persistence."},abstraction:{title:"Chain Abstraction",subtitle:"Layer 3",desc:"Native state-machine level abstraction. Universal Address controls 15+ chains. No-MPC multi-curve derivation. Intent Engine + Solver Network."},payment:{title:"Payment & Trust",subtitle:"Layer 4",desc:"Aeterna AP2 authorization framework + x402 micropayments. Paymaster for gas abstraction. Solves AI hallucination spending problem."}},techSpecs:{systemModules:"System Modules",protocolSpecifications:"Specifications",description:"A modular stack designed for RWA tokenization and Open UBI. Seamlessly integrated from consensus to application layer.",infrastructure:{title:"Infrastructure",subtitle:"LAYER 01",description:"Built on Aeterna Core + Aeterna SDK. Three-layer decoupling: Execution (Multi-VM), DA (Aeterna DA), Settlement (Aeterna BFT/DAG).",framework:"Framework",daLayer:"DA Layer",stateSync:"State Sync"},aiEngine:{title:"AI Engine",subtitle:"LAYER 02",description:"Aeterna AgentCore: On-chain orchestrator (WASM), Aeterna Inference for verifiable ZK/TEE proofs, Aeterna Subnet for incentive markets.",inference:"Inference",verifiability:"Verifiability",memory:"Memory"},abstraction:{title:"Abstraction",subtitle:"LAYER 03",description:"Universal Address (UA) with No-MPC multi-curve derivation. One key signs all chains. 100% on-chain Solver auction.",mechanism:"Mechanism",transport:"Transport",settlement:"Settlement"},payment:{title:"Payments",subtitle:"LAYER 04",description:"Aeterna AP2 (Intent/Cart authorization) + x402 Protocol for AI micropayments. State-machine level Paymaster.",standard:"Standard",auth:"Auth",safety:"Safety"},consensus:{title:"Consensus",subtitle:"CORE",description:"Aeterna DAG + Aeterna Consensus: 160K+ TPS, sub-100ms finality, O(n) message complexity. Aeterna BFT as fallback.",architecture:"Architecture",latency:"Latency",throughput:"Throughput"},multiVM:{title:"Multi-VM",subtitle:"EXECUTION",description:"Rust VM (highest performance), Aeterna Move (parallel execution), Aeterna WASM (cross-chain), EVM (ecosystem compatibility).",primaryVM:"Primary VM",safetyVM:"Safety VM",legacy:"Legacy"}},tokenomics:{economicLayer:"Economic Layer",title:"AETHER Tokenomics",description:"A self-sustaining economic flywheel. Protocol revenue converts to deflation and staker rewards. >90% yields from real protocol income. Foundation for Open UBI.",totalSupply:"Total Supply",takerFee:"Protocol Fee",burnRatio:"Burn Ratio",stakeReward:"Stake Reward",fixedCap:"Fixed Cap",inStablecoins:"In Stablecoins",fromBuybacks:"From Buybacks",realYield:"Real Yield",flywheel:"Flywheel",utility:"Utility",whitepaper:"Whitepaper",deflationaryEngine:"Dutch Auction Buyback & Burn",deflationaryDesc:"Aeterna uses Dutch Auction for community buyback to prevent whale dumping. Protocol revenue (stablecoins) funds the auction, 90% burned, 10% distributed to stakers.",burnRate:"90% Burn Rate",burnRateDesc:"Repurchased AETHER is permanently removed from circulating supply via Dutch Auction.",realYieldPercent:"10% Real Yield",realYieldDesc:"Protocol income is shared back with long-term stakers. >90% yields from real revenue, ensuring sustainability.",resourceSystem:"Resource System",resourceSystemDesc:"Stake AETHER to receive daily {rp} Resource Points{/rp}. Resource Points cover transfers, swaps, cross-chain operations for FREE. Core mechanism for RWA business adoption.",networkSecurity:"Network Security",networkSecurityDesc:"AETHER powers Proof-of-Stake consensus. Stakers secure Aeterna DAG layer and earn low-inflation safety rewards (3-5% initial, decreasing to zero).",resourceGas:"Resource Gas",resourceGasDesc:"Higher stakes grant more free daily operations. Points reset daily, encouraging continuous staking. When depleted, burn minimal AETHER as fallback.",governance:"Governance",governanceDesc:"Participate in Solver Network parameter updates, fee structure voting, and strategic treasury allocations.",tokenomicsV1:"Tokenomics v1.0",released:"Released: December 2025",abstract:"Abstract",abstractDesc:"AETHER drives network security, governance, and self-sustaining economic flywheel. Protocol revenue directly converts to deflation and staker rewards without external subsidies.",supplyControl:"1. Supply Control",hardCap:"Hard Cap:",hardCapValue:"1 Billion AETHER",dynamicDeflation:"Dynamic Deflation:",dynamicDeflationDesc:"Buyback burn exceeds inflation long-term, achieving NET DEFLATION.",whitepaperDownload:"Whitepaper Download",whitepaperDownloadDesc:"Access full mathematical proofs for the Dutch Auction buyback and burn mechanics.",downloadPDF:"Download PDF"},roadmap:{title:"Deployment Roadmap",subtitle:"Roadmap",description:"Our strategic path towards RWA Infrastructure and Open UBI realization.",phase1:{title:"Phase 1: Foundation",status:"completed",date:"Q1-Q2",items:["Aeterna Core Mainnet","Aeterna BFT Consensus","Basic Chain Abstrac