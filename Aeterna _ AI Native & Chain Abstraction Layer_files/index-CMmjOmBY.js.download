 Conectadas",finality:"Finalidad",bridgeHacks:"Hacks de Puente",readDocumentation:"Leer Documentación",aiAgentSDK:"SDK Agente IA",universalAddress:"Dirección Universal"},ecosystem:{interoperability:"Interoperabilidad",nativeConnection:"Conexión Nativa",chains:"15+ Cadenas"},investors:{badge:"Respaldado por",title:"Nuestros Inversores",description:"Instituciones de clase mundial y socios estratégicos impulsando la misión de Aeterna de redefinir la infraestructura RWA global.",leadLabel:"Inversores Principales",strategicLabel:"Socios Estratégicos"}},p1={en:a1,zh:l1,ko:s1,ja:u1,vi:c1,"zh-TW":d1,es:f1},Hy=re.createContext(void 0),rt=()=>{const e=re.useContext(Hy);if(!e)throw new Error("useI18n must be used within I18nProvider");return e},h1=({children:e})=>{const[t,i]=re.useState(()=>{const s=localStorage.getItem("aeterna-language");if(s&&(s==="en"||s==="zh"))return s;const d=navigator.language.toLowerCase();return d.includes("zh-tw")||d.includes("zh-hk")?"zh-TW":d.startsWith("zh")?"zh":d.startsWith("ko")?"ko":d.startsWith("ja")?"ja":d.startsWith("vi")?"vi":d.startsWith("es")?"es":"en"}),o=s=>{i(s),localStorage.setItem("aeterna-language",s)};re.useEffect(()=>{localStorage.setItem("aeterna-language",t)},[t]);const l={language:t,setLanguage:o,t:p1[t]};return c.jsx(Hy.Provider,{value:l,children:e})};/**
