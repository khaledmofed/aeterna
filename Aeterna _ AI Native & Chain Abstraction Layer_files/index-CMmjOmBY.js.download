,payment:{title:"Pago y Confianza",subtitle:"Capa 4",desc:"Marco de autorización Aeterna AP2 + micro-pagos x402. Paymaster para abstracción de gas. Resuelve el gasto por alucinaciones de IA."}},techSpecs:{systemModules:"Módulos del Sistema",protocolSpecifications:"Especificaciones del Protocolo",description:"Una pila modular diseñada para la tokenización de RWA y UBI Abierto. Perfectamente integrada desde el consenso hasta la capa de aplicación.",infrastructure:{title:"INFRAESTRUCTURA",subtitle:"CAPA 01",description:"Construido sobre Aeterna Core + SDK Aeterna (bifurcación Sui). Desacoplamiento de tres capas: Ejecución (Multi-VM), DA (Aeterna DA) y Asentamiento (Aeterna BFT/DAG).",framework:"Marco",daLayer:"Capa DA",stateSync:"Sincronización de Estado"},aiEngine:{title:"MOTOR IA",subtitle:"CAPA 02",description:"Aeterna AgentCore: Orquestador On-chain (WASM), Aeterna Inference para pruebas verificables ZK/TEE, Aeterna Subnet para mercados incentivados.",inference:"Inferencia",verifiability:"Verificabilidad",memory:"Memoria"},abstraction:{title:"ABSTRACCIÓN",subtitle:"CAPA 03",description:"Dirección Universal (UA) con derivación multi-curva No-MPC. Una llave firma para cualquier cadena. Subastas de Solver 100% On-Chain.",mechanism:"Mecanismo",transport:"Transporte",settlement:"Asentamiento"},payment:{title:"PAGO",subtitle:"CAPA 04",description:"Aeterna AP2 (Autorización de Intención/Carrito) + Protocolo x402 para micro-pagos de IA. Paymaster a nivel de máquina de estado.",standard:"Estándar",auth:"Auth",safety:"Seguridad"},consensus:{title:"CONSENSO",subtitle:"NÚCLEO",description:"Aeterna DAG + Consenso Aeterna: 160k+ TPS, <100ms finalidad, cumplejidad de mensaje O(n). Aeterna BFT como respaldo.",architecture:"Arquitectura",latency:"Latencia",throughput:"Rendimiento"},multiVM:{title:"MULTI-VM",subtitle:"EJECUCIÓN",description:"Rust VM (Rendimiento Extremo), Aeterna Move (Ejecución Paralela), Aeterna WASM (Interoperabilidad), EVM (Compatibilidad Eco).",primaryVM:"VM Principal",safetyVM:"VM de Seguridad",legacy:"Legado"}},tokenomics:{economicLayer:"Capa Económica",title:"TOKENOMICS DE AETHER",description:"Un volante económico autosostenible. Los ingresos del protocolo impulsan la deflación y las recompensas para los stakers. >90% del rendimiento proviene de ingresos reales del protocolo. La piedra angular del UBI Abierto.",totalSupply:"Suministro Total",takerFee:"Comisión del Protocolo",burnRatio:"Ratio de Quema",stakeReward:"Recompensa de Staking",fixedCap:"Límite Fijo",inStablecoins:"En Stablecoins",fromBuybacks:"De Recompras",realYield:"Rendimiento Real",flywheel:"Volante",utility:"Utilidad",whitepaper:"Whitepaper",deflationaryEngine:"Mecanismo de Recompra y Quema por Subasta Holandesa",deflationaryDesc:"Aeterna emplea recompras comunitarias mediante Subasta Holandesa para prevenir el dumping de ballenas. Los ingresos del protocolo (en stablecoins) financian las subastas, quemando el 90% y distribuyendo el 10% a los stakers.",burnRate:"Tasa de Quema del 90%",burnRateDesc:"Los AETHER recomprados se eliminan permanentemente del suministro circulante a través de subastas holandesas.",realYieldPercent:"10% Rendimiento Real",realYieldDesc:"Los ingresos del protocolo se comparten con los stakers a largo plazo. Más del 90% del rendimiento proviene de ingresos reales, asegurando la sostenibilidad.",resourceSystem:"Sistema de Recursos",resourceSystemDesc:"Haga staking de AETHER para ganar {rp}Puntos de Recursos{/rp} diariamente. Los recursos cubren tarifas de gas para transferencias, intercambios y operaciones entre cadenas de forma gratuita. Un mecanismo central para la adopción de RWA empresarial.",networkSecurity:"Seguridad de la Red",networkSecurityDesc:"AETHER impulsa el consenso PoS. Los stakers aseguran la capa Aeterna DAG y ganan recompensas de baja inflación (inicialmente 3-5%, disminuyendo a 0).",resourceGas:"Gas de Recursos",resourceGasDesc:"Cuanto más stake haga, más operaciones gratuitas obtendrá. Los puntos se reinician diariamente, incentivando el staking continuo. Se quema una cantidad extremadamente pequeña de AETHER al agotarse.",governance:"Gobernanza",governanceDesc:"Participe en actualizaciones de parámetros de la Red de Solver, votos sobre la estructura de tarifas y asignaciones estratégicas del tesoro.",tokenomicsV1:"Tokenomics v1.0",released:"Lanzado: Dic 2025",abstract:"Resumen",abstractDesc:"AETHER impulsa la seguridad de la red, la gobernanza y un volante económico autosostenible. Los ingresos del protocolo se canalizan directamente hacia la deflación y las recompensas de staking, sin subsidios externos.",supplyControl:"1. Control de Suministro",hardCap:"Límite Duro:",hardCapValue:"1 Billón AETHER",dynamicDeflation:"Deflación Dinámica:",dynamicDeflationDesc:"A largo plazo, la quema por recompra supera la inflación, logrando una deflación neta.",whitepaperDownload:"Descargar Whitepaper",whitepaperDownloadDesc:"Obtenga la prueba matemática completa del Mecanismo de Recompra y Quema por Subasta Holandesa.",downloadPDF:"Descargar PDF"},roadmap:{title:"Hoja de Ruta de Despliegue",subtitle:"HOJA DE RUTA",description:"El camino estratégico hacia la Infraestructura RWA y el UBI Abierto.",phase1:{title:"Fase 1: Fundación",status:"Completado",date:"Q1-Q2",items:["Aeterna Core Mainnet","Aeterna BFT Consensus","Abstracción de Cadena Básica (MVP Multisig)","Emisión de Token AETHER","Sistema de Recursos"]},phase2:{title:"Fase 2: Integración IA",status:"En Progreso",date:"Q3-Q4",items:["Aeterna Inference Mainnet","Incentivos Aeterna Subnet","Integración Protocolo A2A","Soporte Multi-VM (EVM, Aeterna Move)"]},phase3:{title:"Fase 3: Abstracción de Cadena",status:"Próximamente",date:"Año 2 Q1-Q2",items:["Despliegue Completo de Dirección Universal","Derivación Multi-Curva No-MPC","Descentralización de Red de Solver","Soporte para 15+ Cadenas"]},phase4:{title:"Fase 4: Expansión del Ecosistema",status:"Próximamente",date:"Año 2 Q3+",items:["Actualización Aeterna DAG + Consenso Aeterna","Cara