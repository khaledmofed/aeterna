// Initialize Autonomous Agent
const supervisor = new Agent({
  id: 'agent_x7f2',
  model: 'llama-3.1-405b-ritual',
  memory: new Walrus.VectorStore({
    bucketId: '0x123...abc'
  }),
});

// Define Intent Listener
supervisor.onIntent('OptimizeYield', async (ctx) => {
  // 1. Inference Verification (ZK Proof)
  const strategy = await ctx.infernet.query({
    prompt: 'Analyze highest APY pools on Arbitrum',
    proof: true
  });

  // 2. Execute via Solver
  if (strategy.apy > 15.0) {
    await ctx.execute({
      chain: 'arbitrum',
      call: 'aave.deposit(USDC)',
      amount: ctx.params.amount
    });
  }
});`,language:"typescript",isVisible:t==="agent"}),c.jsx(bg,{code:`import { UniversalAddress, Solver } from '@aeterna/sdk';

// 1. Setup Universal Address (UA)
const ua = new UniversalAddress({
  curves: ['secp256k1', 'ed25519'],
  auth: 'google_ap2_passkey'
});

console.log(ua.address); // 'alice.aeterna'

// 2. Sign Cross-Chain Intent
const intent = await ua.sign({
  target: 'solana',
  action: 'swap',
  params: {
    from: 'SOL',
    to: 'USDC',
    amount: 5.0
  }
});

// 3. Broadcast to Solver Network
const txHash = await Solver.broadcast(intent, {
  maxFee: '0.01 ETH',
  speed: 'turbo'
});`,language:"typescript",isVisible:t==="chain"})]})]})})})]})})]})},Gc=["completed","已完成","完了","Hoàn thành","Completado","완료됨"],Ag=["current","进行中","進行中","Đang diễn ra","En Progreso","현재"],mC=["upcoming","即将到来","即將到來","予定","Sắp tới","Próximamente","예정됨"],gC=()=>{const{t:e}=rt(),t=[{title:e.roadmap.phase1.title,status:e.roadmap.phase1.status,date:e.roadmap.phase1.date,icon:ss,items:e.roadmap.phase1.items},{title:e.roadmap.phase2.title,status:e.roadmap.phase2.status,date:e.roadmap.phase2.date,icon:Zr,items:e.roadmap.phase2.items},{title:e.roadmap.phase3.title,status:e.roadmap.phase3.status,date:e.roadmap.phase3.date,icon:Ql,items:e.roadmap.phase3.items},{title:e.roadmap.phase4.title,status:e.roadmap.phase4.status,date:e.roadmap.phase4.date,icon:eo,items:e.roadmap.phase4.items}],i=o=>Gc.includes(o)?"border-nexus-yellow bg-nexus-yellow text-black shadow-[0_0_10px_#EBFF00]":Ag.includes(o)?"border-nexus-yellow animate-pulse shadow-[0_0_20px_#EBFF00] bg-black":"border-neutral-800 bg-neutral-900";return c.jsxs("section",{className:"py-32 bg-black relative overflow-hidden max-w-[100vw]",id:"roadmap",children:[c.jsx("div",{className:"absolute top-0 left-1/2 -translate-x-1/2 w-[min(100%,100vw)] h-[min(1000px,150vh)] bg-nexus-yellow/5 rounded-full blur-[120px] pointer-events-none opacity-20"}),c.jsxs("div",{className:"container mx-auto px-6 relative z-10",children:[c.jsx("div",{className:"text-center mb-24",children:c.jsxs(se,{children:[c.jsxs("h2",{className:"text-3xl sm:text-4xl md:text-6xl font-bold mb-6 tracking-tighter",children:[e.roadmap.title.split(" ").slice(0,-1).join(" ")," ",c.jsx("span",{className:"text-nexus-yellow",children:e.roadmap.subtitle})]}),c.jsx("p",{className:"text-neutral-400 max-w-xl mx-auto",children:e.roadmap.description})]})}),c.jsxs("div",{className:"max-w-5xl mx-auto relative overflow-hidden",children:[c.jsx("div",{className:"absolute top-0 left-8 md:left-1/2 -translate-x-1/2 w-px h-full bg-white/10 overflow-hidden",children:c.jsx("div",{classNa