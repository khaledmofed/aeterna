p and Mobile.",comingSoon:"Coming Soon",appStore:"App Store",googlePlay:"Google Play",version:"v2.4.0 (Stable) • iOS 16+ • Android 13+",scanToInstall:"Scan to",install:"Install",beta:"Beta",biometric:"Biometric",biometricDesc:"Hardware Enclave Signing",realtime:"Real-time",realtimeDesc:"Push Notifications for Alpha",multiChain:"Multi-Chain",multiChainDesc:"15+ Networks Supported",totalAssets:"Total Assets",liveAgent:"Live Agent",arbitrageOpportunity:"Arbitrage Opportunity",detectedPriceSpread:"Detected price spread on Uniswap v3 vs Orca.",estProfit:"Est. Profit:",recentActivity:"Recent Activity",bridgeToBase:"Bridge to Base",minsAgo:"mins ago",cancel:"Cancel",gasSaved:"AI Group Intelligence",paymaster:"Top E2EE Security",biometricAuth:"Private Decentralized",verified:"Verified",unlockBeta:"Unlock Beta",enterInviteCode:"Enter Invite Code",inviteCodePlaceholder:"e.g., AETERNA-888",verify:"Verify",invalidCode:"Invalid or expired invite code",betaUnlocked:"Beta Unlocked"},aiCoreEngine:{layer2:"Layer 2: AI Engine",title:"Decentralized",agentCore:"Aeterna AgentCore",description:"A never-down Agent network. On-chain orchestrator, Aeterna Inference for verifiable AI, Aeterna Subnet for incentives, Aeterna Memory for persistence.",orchestratorBrain:"Orchestrator Brain",orchestratorDesc:"On-Chain Supervisor Agent",cosmWasmContracts:"Aeterna WASM Contracts",taskDecomposition:"Task Decomposition (ReAct)",fullStateOnChain:"Full State On-Chain",inferenceEngine:"Inference Engine",ritualInfernet:"Aeterna Inference",verifiableProofs:"Verifiable ZK/TEE Proofs",models:"Llama 3.1 405B / Claude / GPT-4o",noSinglePoint:"No Single Point of Failure",ecoIncentives:"Eco Incentives",bittensorSubnets:"Aeterna Subnet",computeStaking:"Compute Staking",modelCompetition:"Model Competition",yumaConsensus:"Aeterna Consensus",longTermMemory:"Long-Term Memory",walrusVectorDB:"Aeterna Storage + Vector DB",decentralizedBlob:"Decentralized Blob Storage",blobIdInContract:"Blob ID in Contract",vectorRetrieval:"Vector Retrieval",toolLayer:"Tool Layer",nativeIntegration:"Native Integration",dexOracleAccess:"DEX / Oracle Access",ibcBridgeCalls:"Aeterna Bridge Calls",automatedDeFi:"Automated DeFi",orchestrator:"Orchestrator",orchestratorDetail:"The autonomous supervisor running on-chain. It decomposes high-level user intents into executable low-level WASM/EVM transactions using the ReAct pattern.",reactLoopStatus:"ReAct Loop Status",active:"Active",reason:"Reason",act:"Act",observe:"Observe",runtime:"Runtime",cosmWasm:"Aeterna WASM",state:"State",persistent:"Persistent",ritualInference:"Aeterna Inference",ritualDetail:"Decentralized inference network for verifiable AI. Supports ZK/TEE proofs. Integrates with smart contracts via simple API.",networkNodes:"Network Nodes",infernet:"Aeterna Nodes",verifiability:"Verifiability",zkTeeOptimistic:"ZK / TEE / No Proof",supportedModels:"Supported Models",modelsList:"Llama 3.1, Claude, GPT-4o",bittensor:"Aeterna Subnet",bittensorDetail:"Incentive market where users stake to direct compute. Subnets compete for best models. Emission: 41% miners + 41% validators + 18% subnet owners.",miners:"Miners",runModels:"Run Models",validators:"Validators",rankQuality:"Rank Quality",subnets:"Subnets",tracks:"AI Tracks",emission:"Emission",walrusMemory:"Aeterna Memory",walrusDetail:"Decentralized long-term memory for Agents. Conversation history and vectors stored in Aeterna Storage, Blob ID stored in contract.",blobStorage:"Blob Storage",erasureCoded:"Erasure-coded (Red Stuff), 2/3 fault tolerance",suiBased:"2D Reed-Solomon",vectorIndex:"Vector Index",semanticSearch:"Semantic Search & RAG",context:"Context",aiAgentProtocols:"AI Agent Protocols",protocol:"Protocol",function:"Function",integrationModule:"Integration Module",erc8004:"ERC-8004",erc8004Desc:"AI Agent Identity & Trust Registration",xAgent:"x/agent",x402Desc:"AI Native Micropayments (HTTP 402)",xPay:"x/pay",googleA2A:"A2A",googleA2ADesc:"Agent-to-Agent Communication",hooksIBC:"Hooks + Aeterna Bridge",googleAP2Desc:"Agent Payment Authorization Framework",xAp2Pay:"x/ap2pay"},chainAbstraction:{layer3Abstraction:"Layer 3 Chain Abstraction",title:"One Key.",subtitle:"Every Door.",description:"Universal Address (UA): One 20-byte global address maps and controls 15+ chains (Ethereum, Solana, Bitcoin...). Format: alice.aeterna. No-MPC multi-curve derivation.",intentExecutionDemo:"Intent Execution Demo",crossChain:"Cross-Chain",singleSignature:"Single Signature",singleSignatureDesc:"One key signs all chains (secp256k1, ed25519, secp256r1, BLS12_381)",solverAuction:"Solver Auction",solverAuctionDesc:"100% on-chain Dutch Auction. Zero off-chain black box.",atomicSettlement:"Atomic Settlement",atomicSettlementDesc:"Submit intent → Mempool broadcast → Solver bid → Cross-chain execute → Verify & pay",executeIntent:"Execute Intent",executionComplete:"Execution Complete",processing:"Processing...",uaIdle:"UA Idle",signing:"Signing",solving:"Solving",bridging:"Bridging",complete:"Complete",noMpcSecurity:"No-MPC Security",noMpcSecurityDesc:"State machine AnteHandler supports multi-curve signatures. Your keys never leave your device.",gasAbstraction:"Gas Abstraction",gasAbstractionDesc:"Paymaster at state-machine level. Any token, even cross-chain assets. Solver advances, user settles later.",executionLayer:"Execution Layer",solverNetwork:"Solver Network",solverNetworkDesc:"100% on-chain auction. Zero off-chain black box. Decentralized, censorship-resistant.",dutchAuctionEngine:"Dutch Auction Engine",dutchAuctionDesc:"Unlike AMMs, Solvers bid to fill your order. The price starts high and decays rapidly until a Solver accepts.",decayFrequency:"Decay Frequency",tick:"150ms / tick",decayRatio:"Decay Ratio",linear:"0.5% linear",auctionVenue:"Auction Venue",onChainL3:"100% On-Chain",justInTimeLiquidity:"Just-In-Time Liquidity",justInTimeDesc:"Solvers utilize diverse sources to fund execution instantly on the destination chain, often before the source transaction finalizes.",flashLoans:"Flash Loans (Aave/Uniswap)",privateInventory:"Private Inventory (Wintermute/Jump)",stakedLiquidityVaults:"Staked Liquidity Vaults (SLV)",optimisticSettlement:"Optimistic Settlement",optimisticDesc:"Solvers take on the reorg risk. Users get funds instantly. If a Solver fails to deliver, their stake is slashed and the user is refunded by the SLV.",guaranteedExecution:"Guaranteed Execution"},crossChainManager:{operationsCenter:"Operations Center",intentManager:"Intent",manager:"Manager",active:"Active",history:"History",liveOperations:"Live Operations",pastOperations:"Past Operations",noActiveOperations:"No active operations found.",noHistoryOperations:"No history operations found.",processing:"PROCESSING",completed:"COMPLETED",failed:"FAILED",crossChainSwap:"Cross-Chain Swap",yieldFarmDeposit:"Yield Farm Deposit",bridgeStake:"Bridge & Stake",tokenTransfer:"Token Transfer",nftPurchase:"NFT Purchase",executionFlow:"Execution Flow",intentSigned:"Intent Signed",solverAuction:"Solver Auction",sourceLock:"Source Lock",destinationFill:"Destination Fill",yieldRoute:"Yield Route",optimisticVerify:"Optimistic Verify",transfer:"Transfer",signedViaUA:"Signed via Universal Address",winner:"Winner:",fee:"fee",verifyingDeposit:"Verifying USDC deposit on Arbitrum",releasingSOL:"Releasing SOL on Solana",broadcasting:"Broadcasting to Solver Network",pendingAuction:"Pending Auction Winner",depositToAave:"Deposit to Aave V3",passkeyAuthVerified:"Passkey Auth Verified",ethLocked:"ETH Locked",stakedAtom:"Staked 450 ATOM to Validator #1",oneClickSign:"One-Click Sign",stateRootVerified:"State Root Verified",assetsReceived:"Assets Received",walletConnected:"Wallet Connected",slippageExceeded:"Slippage Exceeded (>3%)",cancelled:"Cancelled",cancel:"Cancel",boostGas:"Boost Gas",viewExplorer:"View Explorer",validatedBy:"Validated by Aeterna L3",solver:"Solver:",selectOperation:"Select an operation to view details",remaining:"remaining",done:"Done",stopped:"Stopped"},exchangeSection:{zkDarkPoolMode:"ZK-Dark Pool Mode",hyperPerformanceMode:"Hyper-Performance Mode",invisible:"Invisible",liquidity:"Liquidity.",institutional:"Institutional",velocity:"Velocity.",darkPoolDesc:"Execute large block orders without slippage or information leakage. Aeterna DEX uses ZK-SNARKs + Bulletproofs + RingCT for complete business privacy. Perfect for RWA enterprise scenarios.",publicCLOBDesc:"The world's fastest on-chain orderbook. Built on Aeterna DAG for <100ms finality and 160K+ TPS. Singleton contract architecture with unified liquidity. Hooks system for RWA compliance.",publicCLOB:"Public CLOB",publicCLOBDesc2:"Transparent orderbook, micro-second matching.",darkPool:"Dark Pool",darkPoolDesc2:"Zero-Knowledge order privacy, Anti-MEV.",launchTerminal:"Launch Terminal",aeternaDex:"Aeterna DEX v2.1",encrypted:"Encrypted",liveFeed:"Live Feed",price:"Price",amount:"Amount",total:"Total",spread:"SPREAD 0.01%",zkSpread:"Z-KNOWLEDGE SPREAD",websocketConnected:"WebSocket Connected",privateOrders:"Private Orders",privateOrdersDesc:"Utilizes ZK-SNARKs to keep order size and direction hidden from the public mempool until the moment of execution, preventing information leakage.",mevProtection:"MEV Protection",mevProtectionDesc:"Encrypted mempool ensures fair ordering. Sandwich attacks and front-running are mathematically impossible due to TEE-based sequencing.",atomicComposability:"Atomic Composability",atomicComposabilityDesc:"Combine spot, perp, and lending actions in a single transaction block. Execute complex strategies across the entire ecosystem instantly.",submsLatency:"Sub-ms Latency",submsLatencyDesc:"Built on the Narwhal + Bullshark DAG consensus, achieving 160k TPS with guaranteed finality under 100ms for HFT-grade performance.",underTheHood:"Under the Hood",cryptographicInvisibility:"Cryptographic",invisibilityCloak:"Invisibility Cloak",cryptographicDesc:"How Aeterna achieves total order privacy while maintaining a decentralized, permissionless state.",clientSideZK:"Client-Side ZK Proofs",clientSideZKDesc:"Before an order leaves your device, the Aeterna SDK generates a Groth16/Plonk proof. This proves you have the funds and the intent is valid, without revealing:",orderSize:"Order Size",limitPrice:"Limit Price",direction:"Direction (Buy/Sell)",publicMempoolView:"// Public Mempool View",teeSequencing:"TEE Sequencing (SGX)",teeSequencingDesc:"Encrypted orders are routed to validators running Intel SGX Enclaves. The matching engine runs inside this secure black box. Order details are decrypted only microseconds before matching.",antiMevGuarantee:"Anti-MEV Guarantee",antiMevDesc:"Block builders cannot front-run trades they cannot see.",hardwareRoot:"Hardware Root of Trust",hardwareRootDesc:"Remote attestation proves code integrity on-chain.",clickToEnablePublic:"Click to enable Public High-Performance Mode",clickToEnableZK:"Click to enable ZK-Privacy Dark Pool Mode",launchInteractiveTerminal:"Launch Interactive Trading Terminal Demo"},comparison:{benchmark:"Benchmark",technical:"Technical",superiority:"Superiority",description:"Aeterna is the only RWA infrastructure offering native state-machine chain abstraction and decentralized AI inference at the consensus layer.",coreFeature:"Core Feature",chainAbstraction:"Chain Abstraction",nativeNoMpc:"Native (No-MPC)",mpcSignatures:"MPC Signatures",mpcSolver:"MPC + Solver",none:"None",aiEngine:"AI Engine",ritualBittensor:"Aeterna Inference + Subnet",basicML:"Basic ML",consensus:"Consensus",narwhalBullshark:"Aeterna DAG + Consensus",nightshade:"Nightshade",cometBFT:"CometBFT",paymentTrust:"Payment Trust",ap2x402:"Aeterna AP2 + x402",vmSupport:"VM Support",multiVMRustMove:"Rust/Move/WASM/EVM",wasm:"WASM",moveOnly:"Move Only",viewOnDesktop:"View on desktop for full comparison"},useCases:{realWorldApplication:"RWA Application Scenarios",builtFor:"Built for",complexScenarios:"RWA × DeFi × AI × Privacy",description:"Three pillars of RWA: DeFi integration, AI integration, Business privacy. Every Web2 product can be rebuilt with Web3 + AI.",headlessEcommerce:"D-Commerce",web3Retail:"Decentralized Commerce",nftFractional:"Sellers pay 0.02-0.1% (vs 15-40% platform fees)",aiDriven:"AI Agent matching and recommendation",gaslessPayments:"Gasless via Resource System",supplyChain:"Supply chain RWA + AI credit scoring",decentralizedO2O:"Tokenized Real Estate",depinDelivery:"RWA Property",tokenIncentives:"Fractional NFT ownership (ERC-1155), invest from $10",zkSnarks:"Smart contract auto-distributes rent",smartContract:"AI Agent property management",carbonNeutral:"Cross-border investment via chain abstraction",hotelBooking:"Open UBI",rwaHospitality:"Value Redistribution",rwaRoomNFTs:"Data ownership via DID, users monetize their data",aiAgentsNegotiate:"Attention economy: browse, interact, share → micro rewards",travelToEarn:"Staking dividends + deflation appreciation",dynamicPricing:"AI training data contribution rewards"},developers:{documentation:"Documentation",writeOnce:"Write Once.",deployEverywhere:"Deploy Everywhere.",description:"The Aeterna SDK abstracts away the complexity of cross-chain cryptography and decentralized AI. Write logic in TypeScript, Rust, or Python. We handle the consensus, proofs, and execution.",supportedVMs:"Supported VMs",connectedChains:"Connected Chains",finality:"Finality",bridgeHacks:"Bridge Hacks",readDocumentation:"Read the Documentation",aiAgentSDK:"AI Agent SDK",universalAddress:"Universal Address"},ecosystem:{interoperability:"Interoperability",nativeConnection:"Native Connection to",chains:"15+ Chains"},investors:{badge:"Backed By",title:"Our Investors",description:"World-class institutions and strategic partners powering Aeterna's mission to reshape global RWA infrastructure.",leadLabel:"Lead Investors",strategicLabel:"Strategic Partners"}},l1={header:{architecture:"架构",exchange:"交易所",tokenomics:"代币经济学",useCases:"用例",docs:"文档",testnet:"测试网",launchApp:"启动应用",infrastructure:"基础设施",aiEngine:"AI引擎",abstraction:"AETERNA",payment:"支付",narwhalDAG:"Aeterna DAG",multiVM:"多虚拟机",core:"核心 //",aeternaStack:"Aeterna 四层架构",cosmosSovereign:"Aeterna Core + SDK",ritualBittensor:"Aeterna Inference + Subnet",universalAddress:"Universal Address",ap2x402:"Aeterna AP2 + x402",tps:"16万+ TPS",rustMoveEvm:"Rust/Move/EVM",connect:"连接",testnetV2:"测试网 V2.1"},hero:{consensusLive:"Aeterna DAG + Aeterna Consensus 已上线",chain:"AETERNA",abstraction:"",description:"Open UBI 时代的 RWA 基础设施。使用{oneAddress}一个 Universal Address{/oneAddress}控制15+条链。通过{autonomous}自主执行{/autonomous}和{trustless}无需信任的支付{/trustless}赋能AI Agent。",launchAIAgent:"启动AI Agent",readWhitepaper:"阅读白皮书",tps:"TPS (Aeterna DAG)",finality:"最终确认",architecturalLayers:"架构层",onChainAI:"链上AI"},features:{title:"四层",subtitle:"解耦架构",description:"解耦、模块化、可独立升级。为 RWA 基础设施和 Open UBI 而构建。",infrastructure:{title:"基础设施层",subtitle:"第一层",desc:"Aeterna Core + Aeterna SDK。Aeterna DAG + Aeterna Consensus 实现 16万+ TPS，亚100ms最终性。包含 Aeterna DA 和 Aeterna Storage。"},aiCore:{title:"AI引擎层",subtitle:"第二层",desc:"去中心化 Aeterna AgentCore。链上编排器、Aeterna Inference 可验证推理、Aeterna Subnet 激励市场、Aeterna Memory 长期记忆。"},abstraction:{title:"万链归一",subtitle:"第三层",desc:"一把钥匙签所有链。Universal Address 控制15+条链。No-MPC 多曲线派生。意图驱动，Solver 竞价执行。"},payment:{title:"支付与信任层",subtitle:"第四层",desc:"Aeterna AP2 授权框架 + x402 微支付协议。状态机级别 Paymaster。解决 AI「幻觉消费」问题。"}},techSpecs:{systemModules:"系统模块",protocolSpecifications:"规范",description:"为 RWA 代币化和 Open UBI 设计的模块化堆栈。从共识到应用层无缝集成。",infrastructure:{title:"基础设施",subtitle:"第一层",description:"基于 Aeterna Core + Aeterna SDK 构建。三层解耦：执行层(多VM)、DA层(Aeterna DA)、结算层(Aeterna BFT/DAG)。",framework:"框架",daLayer:"数据可用性层",stateSync:"状态同步"},aiEngine:{title:"AI引擎",subtitle:"第二层",description:"Aeterna AgentCore：链上编排器(WASM)、Aeterna Inference 可验证 ZK/TEE 证明、Aeterna Subnet 激励市场。",inference:"推理",verifiability:"可验证性",memory:"记忆"},abstraction:{title:"万链归一",subtitle:"第三层",description:"Universal Address + No-MPC 多曲线派生。一把钥匙签所有链。100% 链上 Solver 拍卖。",mechanism:"机制",transport:"传输",settlement:"结算"},payment:{title:"支付",subtitle:"第四层",description:"Aeterna AP2（意图/购物车授权）+ x402 协议 AI 微支付。状态机级别 Paymaster。",standard:"标准",auth:"授权",safety:"安全性"},consensus:{title:"共识",subtitle:"核心",description:"Aeterna DAG + Aeterna Consensus：16万+ TPS，亚100ms最终性，O(n)消息复杂度。Aeterna BFT 作为备用。",architecture:"架构",latency:"延迟",throughput:"吞吐量"},multiVM:{title:"多虚拟机",subtitle:"执行",description:"Rust VM（最高性能）、Aeterna Move（并行执行）、Aeterna WASM（跨链兼容）、EVM（生态兼容）。",primaryVM:"主虚拟机",safetyVM:"安全虚拟机",legacy:"兼容层"}},tokenomics:{economicLayer:"经济层",title:"AETHER 代币经济学",description:"自循环经济飞轮。协议收入直接转化为通缩和质押者奖励。>90% 收益来自真实协议收入。Open UBI 的基础。",totalSupply:"总供应量",takerFee:"协议费",burnRatio:"销毁比例",stakeReward:"质押奖励",fixedCap:"固定上限",inStablecoins:"以稳定币计价",fromBuybacks:"来自回购",realYield:"真实收益",flywheel:"飞轮",utility:"实用性",whitepaper:"白皮书",deflationaryEngine:"荷兰拍卖回购销毁",deflationaryDesc:"Aeterna 采用荷兰拍卖进行社区回购，防止大户砸盘。协议收入（稳定币）资助拍卖，90%销毁，10%分配给质押者。",burnRate:"90% 销毁率",burnRateDesc:"回购的 AETHER 通过荷兰拍卖永久从流通供应中移除。",realYieldPercent:"10% 真实收益",realYieldDesc:"协议收入与长期质押者分享。>90% 收益来自真实收入，确保可持续性。",resourceSystem:"资源系统",resourceSystemDesc:"质押 AETHER 每日获得{rp}资源积分{/rp}。资源积分覆盖转账、交换、跨链操作完全免费。RWA 商业落地的核心机制。",networkSecurity:"网络安全",networkSecurityDesc:"AETHER 驱动权益证明共识。质押者保护 Aeterna DAG 层并获得低通胀安全奖励（初始3-5%，逐步递减至零）。",resourceGas:"资源Gas",resourceGasDesc:"更高质押量授予更多每日免费操作。积分每日重置，鼓励持续质押。积分耗尽后燃烧极少量 AETHER 作为兜底。",governance:"治理",governanceDesc:"参与 Solver 网络参数更新、费用结构投票和战略金库分配。",tokenomicsV1:"代币经济学 v1.0",released:"发布时间：2025年12月",abstract:"摘要",abstractDesc:"AETHER 驱动网络安全、治理和自循环经济飞轮。协议收入直接转化为通缩和质押者奖励，无需外部补贴。",supplyControl:"1. 供应控制",hardCap:"硬上限：",hardCapValue:"10亿 AETHER",dynamicDeflation:"动态通缩：",dynamicDeflationDesc:"回购销毁量长期超过通胀，实现净通缩。",whitepaperDownload:"白皮书下载",whitepaperDownloadDesc:"访问荷兰拍卖回购和销毁机制的完整数学证明。",downloadPDF:"下载PDF"},roadmap:{title:"部署路线图",subtitle:"路线图",description:"通往 RWA 基础设施和 Open UBI 实现的战略路径。",phase1:{title:"第一阶段：基础",status:"已完成",date:"Q1-Q2",items:["Aeterna Core 主网上线","Aeterna BFT 共识","基础链抽象（MVP 多签）","AETHER 代币上线","资源积分系统"]},phase2:{title:"第二阶段：AI 集成"