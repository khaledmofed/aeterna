ve/Uniswap)",privateInventory:"Inventario Privado (Wintermute/Jump)",stakedLiquidityVaults:"Bóvedas de Liquidez en Staking (SLV)",optimisticSettlement:"Asentamiento Optimista",optimisticDesc:"El Solver asume el riesgo de reorganización. El usuario recibe fondos al instante. Si el Solver falla, el stake se recorta, el usuario es reembolsado desde SLV.",guaranteedExecution:"Ejecución Garantizada"},crossChainManager:{operationsCenter:"Centro de Operaciones",intentManager:"Intención",manager:"Gerente",active:"Activo",history:"Historial",liveOperations:"Operaciones en Vivo",pastOperations:"Operaciones Pasadas",noActiveOperations:"No hay operaciones activas.",noHistoryOperations:"No hay operaciones históricas.",processing:"Procesando",completed:"Completado",failed:"Fallido",crossChainSwap:"Intercambio Cross-Chain",yieldFarmDeposit:"Depósito Yield Farm",bridgeStake:"Puente y Stake",tokenTransfer:"Transferencia de Token",nftPurchase:"Compra de NFT",executionFlow:"Flujo de Ejecución",intentSigned:"Intención Firmada",solverAuction:"Subasta de Solver",sourceLock:"Bloqueo de Origen",destinationFill:"Relleno de Destino",yieldRoute:"Ruta de Rendimiento",optimisticVerify:"Verificación Optimista",transfer:"Transferencia",signedViaUA:"Firmado vía Dirección Universal",winner:"Ganador:",fee:"Tarifa",verifyingDeposit:"Verificando depósito de USDC en Arbitrum",releasingSOL:"Liberando SOL en Solana",broadcasting:"Transmitiendo a Red de Solvers",pendingAuction:"Esperando ganador de subasta",depositToAave:"Depositar en Aave V3",passkeyAuthVerified:"Autenticación Passkey Verificada",ethLocked:"ETH Bloqueado",stakedAtom:"450 ATOM en staking para Validador #1",oneClickSign:"Firma de un clic",stateRootVerified:"Raíz de Estado Confirmada",assetsReceived:"Activos Recibidos",walletConnected:"Billetera Conectada",slippageExceeded:"Deslizamiento Excedido (>3%)",cancelled:"Cancelado",cancel:"Cancelar",boostGas:"Impulsar Gas",viewExplorer:"Ver Explorador",validatedBy:"Validado por Aeterna L3",solver: